# LiteAI — Variables d'environnement requises
# Copiez ce fichier en .env et remplissez vos valeurs
# NE JAMAIS commiter le fichier .env sur GitHub !

# ─── OBLIGATOIRES ───────────────────────────
# Clé API Hugging Face (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_votre_cle_ici

# Clé secrète Flask (chaîne aléatoire longue)
# Générez avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_moi_avec_une_longue_cle_aleatoire

# URL de la base de données Supabase (PostgreSQL)
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:votre_mdp@db.xxx.supabase.co:5432/postgres

# ─── OPTIONNELS ─────────────────────────────
# Modèle IA par défaut (voir DOCUMENTATION.md pour la liste)
# DEFAULT_MODEL=qwen3-32b
